# --- Raw data archives ---------------------------------------------------
# Large archived raw-data / simulation bundles are kept OUT of version
# control (they are not working files). .tar.gz simulation bundles ARE
# tracked intentionally. To force-add a specific zip: `git add -f file.zip`
*.zip

# --- Python --------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- Environments --------------------------------------------------------
.venv/
venv/
env/

# --- OS / editor cruft ---------------------------------------------------
.DS_Store
Thumbs.db

# --- Claude Code machine-local settings ----------------------------------
# (also covered by the global ignore, repeated here so clones stay clean)
.claude/settings.local.json

# --- LaTeX build artifacts (regenerable) ---------------------------------
*.aux
*.log
*.fls
*.fdb_latexmk
*.synctex.gz
*.nav
*.snm
*.toc
*.out
*.bbl
*.blg
*.run.xml
*.bak

# --- External reference library ------------------------------------------
# REFERENCES/ holds third-party papers/theses (copyright + ~720 MB); kept
# local only. Force-add a specific file if ever needed: `git add -f <path>`
REFERENCES/

# --- Generated 10M analysis arrays (each ~240 MB, over GitHub's limit) ----
fid_10M_unfiltered_*.npy

# --- Extracted raw 10M ASCII (tens of GB; re-extractable from the tarball) -
10M_raw/

# --- Local build-path shim (poster QR path expects parent dir name) -------
UHNeutrinoGroup/Nu2026/poster/nu2026_poster
