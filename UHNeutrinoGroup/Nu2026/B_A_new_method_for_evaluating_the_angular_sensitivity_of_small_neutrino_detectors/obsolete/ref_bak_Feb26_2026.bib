@article{Bugey3_1995,
title = {Search for neutrino oscillations at 15, 40 and 95 meters from a nuclear power reactor at Bugey},
journal = {Nuclear Physics B},
volume = {434},
number = {3},
pages = {503-532},
year = {1995},
issn = {0550-3213},
doi = {https://doi.org/10.1016/0550-3213(94)00513-E},
url = {https://www.sciencedirect.com/science/article/pii/055032139400513E},
author = {B. Achkar and R. Aleksan and M. Avenier and G. Bagieu and J. Bouchez and R. Brissot and J.-F. Cavaignac and J. Collot and M-C. Cousinou and J.P. Cussonneau and others},
abstract = {We report on high statistics measurements of neutrino energy spectra carried out at 15, 40 and 95 meters from a 2800 Megawatt reactor, using detection modules filled with 6Li-loaded liquid scintillator. No oscillations have been observed. Exclusion zones for oscillation parameters are deduced from the observed consistency of the spectra at the three distances. The minimum excluded values of the δm2 and sin22θ parameters are 1 × 10−2eV2and 2 × 10−2 (at 90% CL), respectively.}
}

@article{Bugey3_1996,
title = {The Bugey 3 neutrino detector},
journal = {Nucl. Instrum. Meth. A},
volume = {374},
number = {2},
pages = {164-187},
year = {1996},
issn = {0168-9002},
doi = {https://doi.org/10.1016/0168-9002(96)00220-3},
url = {https://www.sciencedirect.com/science/article/pii/0168900296002203},
author = {M Abbes and B Achkar and S Ait-Boubker and R Aleksan and M Avenier and G Bagieu and J Ballansat and Ch Barnoux and R Bazzoli and J Berger and others},
abstract = {The Bugey 3 experiment, designed to measure oscillations of reactor neutrinos, has used 3 identical detection modules, each of 600 liters, filled with a new 6Li-loaded liquid scintillator. These modules were located in two shielding bunkers, respectively 15 and 40 m away from the reactor core. We describe here the mechanical characteristics of these modules, their shielding, the associated electronics, the trigger, the acquisition systems, the calibration and monitoring of these detectors, and the Monte Carlo simulations of their response to particles. We conclude on the overall performance of this new detection technique which has allowed the recording of 120000 neutrino interactions with good neutron efficiency (49%), low background (2.5 evts/hr) and good energy resolution (4% at 4.4 MeV).}
}

