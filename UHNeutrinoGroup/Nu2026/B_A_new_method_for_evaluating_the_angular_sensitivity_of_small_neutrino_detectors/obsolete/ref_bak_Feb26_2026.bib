@article{HAHN2006134,
title = {Two proposals to measure antineutrinos: At the Braidwood (USA) and the Daya Bay (PRC) reactors},
journal = {Progress in Particle and Nuclear Physics},
volume = {57},
number = {1},
pages = {134-143},
year = {2006},
note = {International Workshop of Nuclear Physics 27th course},
issn = {0146-6410},
doi = {https://doi.org/10.1016/j.ppnp.2005.12.009},
url = {https://www.sciencedirect.com/science/article/pii/S0146641005001511},
author = {Richard L. Hahn},
keywords = {Neutrino oscillations, Neutrino mixing angle, , , Braidwood neutrino experiment, Daya Bay neutrino experiment, Brookhaven National Laboratory, Neutrinos and the BNL Chemistry Department, BNL Nuclear-Chemistry Group},
abstract = {This paper discusses two proposed experiments to measure the unknown neutrino mixing angle, θ13, with high precision, sin22θ13≤0.01. These experiments would search for a reduction in the flux as a function of distance, and for changes in the energy spectrum, of the antineutrinos emitted by nuclear power reactors (a) at the Braidwood reactor in Illinois in the USA, and (b) at the Daya Bay reactor near Shenzhen, China. A key common feature of these experiments is that they would use multiple identical antineutrino detectors placed at different distances from the reactor. Taking the ratio of the neutrino signals from these multiple detectors should lead to high sensitivity by cancelling out many of the systematic errors.}
}

